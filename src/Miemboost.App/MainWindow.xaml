<Window x:Class="Miemboost.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Miemboost"
        Width="1180"
        Height="760"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#070B12"
        FontFamily="Microsoft YaHei UI">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" CornerRadius="18" GlassFrameThickness="0" ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border Margin="18"
            CornerRadius="18"
            BorderBrush="#3D4A5E"
            BorderThickness="1"
            Background="#111923">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="0" Opacity="0.45" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="218" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="18,0,0,18"
                    BorderBrush="#2D394A"
                    BorderThickness="0,0,1,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#202A38" Offset="0" />
                        <GradientStop Color="#151D29" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="18,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                        <Border Width="36" Height="36" CornerRadius="10" Background="#2B3A63">
                            <TextBlock Text="M"
                                       Foreground="#7E8BFF"
                                       FontWeight="Bold"
                                       FontSize="23"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Miemboost"
                                   Foreground="#F6F8FC"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Button Style="{StaticResource NavButtonStyle}" Background="#34405F" Foreground="#FFFFFF">
                            <TextBlock Text="总览" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="游戏库" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="一键加速" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="网络检测" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="进程管理" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="优化记录" />
                        </Button>
                    </StackPanel>

                    <Button Grid.Row="2" Style="{StaticResource NavButtonStyle}">
                        <TextBlock Text="设置" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="30,24,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="96" />
                    <RowDefinition Height="224" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="126" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,18">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Miemboost"
                                   Foreground="#FFFFFF"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="VersionText"
                                   Text="Miemboost 0.1.0-alpha"
                                   Foreground="#AFC1DB"
                                   FontSize="13"
                                   Margin="0,8,0,0" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Width="34" Height="30" Content="-" Click="Minimize_Click" />
                        <Button Width="34" Height="30" Content="□" Click="Maximize_Click" Margin="8,0,0,0" />
                        <Button Width="34" Height="30" Content="×" Click="Close_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource GlassPanelStyle}"
                        Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="当前模式" Foreground="#9FB0C7" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Border Background="#263248" CornerRadius="10" Padding="16,8">
                                    <TextBlock Text="保守" Foreground="#B5C0D1" />
                                </Border>
                                <Border CornerRadius="10" Padding="16,8" Margin="8,0,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6E83FF" Offset="0" />
                                            <GradientStop Color="#7B5CFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="平衡" Foreground="White" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="#263248" CornerRadius="10" Padding="16,8" Margin="8,0,0,0">
                                    <TextBlock Text="激进" Foreground="#B5C0D1" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="已识别游戏" Foreground="#9FB0C7" FontSize="12" />
                            <ComboBox x:Name="GameProcessCombo"
                                      Width="260"
                                      Height="34"
                                      Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="GameProcessCombo_SelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="150"
                                    Height="58"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    BorderBrush="{StaticResource AccentBrushStrong}"
                                    Click="Boost_Click">
                                <TextBlock Text="Boost" />
                            </Button>
                            <Button x:Name="RestoreButton"
                                    Width="90"
                                    Height="58"
                                    Margin="10,0,0,0"
                                    Content="恢复"
                                    IsEnabled="False"
                                    Click="Restore_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="CPU" Foreground="#FFFFFF" FontSize="17" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource GoodBrush}" Margin="0,0,6,0" />
                                    <TextBlock Text="良好" Foreground="#BFD0E6" FontSize="12" />
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock x:Name="CpuText" Text="--%" Foreground="#FFFFFF" FontSize="34" FontWeight="SemiBold" />
                                <TextBlock x:Name="CpuDetailText" Text="正在检测" Foreground="#A9B7CC" Margin="0,8,0,0" />
                            </StackPanel>
                            <Canvas Grid.Row="2" Height="34" Margin="0,0,0,10">
                                <Polyline Points="0,21 10,13 20,18 32,10 46,17 58,15 70,22 82,18 94,25 106,16 120,20 134,13 148,18"
                                          Stroke="{StaticResource GoodBrush}"
                                          StrokeThickness="1.6"
                                          Opacity="0.9" />
                            </Canvas>
                            <ProgressBar x:Name="CpuBar" Grid.Row="3" Height="8" Minimum="0" Maximum="100" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="内存" Foreground="#FFFFFF" FontSize="17" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource WarningBrush}" Margin="0,0,6,0" />
                                    <TextBlock Text="可优化" Foreground="#FFD978" FontSize="12" />
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock x:Name="MemoryText" Text="--%" Foreground="#FFFFFF" FontSize="34" FontWeight="SemiBold" />
                                <TextBlock x:Name="MemoryDetailText" Text="正在检测" Foreground="#A9B7CC" Margin="0,8,0,0" />
                            </StackPanel>
                            <Canvas Grid.Row="2" Height="34" Margin="0,0,0,10">
                                <Polyline Points="0,24 12,23 24,20 36,18 48,21 60,17 72,14 84,16 96,12 108,11 120,9 134,13 148,10"
                                          Stroke="{StaticResource WarningBrush}"
                                          StrokeThickness="1.8"
                                          Opacity="0.9" />
                            </Canvas>
                            <ProgressBar x:Name="MemoryBar" Grid.Row="3" Height="8" Minimum="0" Maximum="100" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="网络" Foreground="#FFFFFF" FontSize="17" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource GoodBrush}" Margin="0,0,6,0" />
                                    <TextBlock Text="良好" Foreground="#BFD0E6" FontSize="12" />
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock x:Name="PingText" Text="-- ms" Foreground="{StaticResource GoodBrush}" FontSize="34" FontWeight="SemiBold" />
                                <TextBlock x:Name="NetworkDetailText" Text="Ping / 抖动 / 丢包" Foreground="#A9B7CC" Margin="0,8,0,0" />
                                <TextBlock x:Name="DnsText" Text="DNS -- ms" Foreground="#A9B7CC" Margin="0,14,0,0" />
                            </StackPanel>
                            <Canvas Grid.Row="2" Height="34">
                                <Polyline Points="0,20 11,17 22,21 33,16 44,19 55,18 66,23 77,20 88,21 99,17 110,18 121,15 132,19 148,16"
                                          Stroke="{StaticResource GoodBrush}"
                                          StrokeThickness="1.6"
                                          Opacity="0.9" />
                            </Canvas>
                        </Grid>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="GPU" Foreground="#FFFFFF" FontSize="17" FontWeight="SemiBold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="GpuStatusDot" Width="7" Height="7" Fill="#64748B" Margin="0,0,6,0" />
                                    <TextBlock x:Name="GpuStatusText" Text="检测中" Foreground="#A9B7CC" FontSize="12" />
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock x:Name="GpuText" Text="--%" Foreground="#FFFFFF" FontSize="34" FontWeight="SemiBold" />
                                <TextBlock x:Name="GpuDetailText"
                                           Text="正在检测"
                                           Foreground="#A9B7CC"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                            <Canvas Grid.Row="2" Height="34">
                                <Polyline Points="0,18 12,18 24,18 36,18 48,18 60,18 72,18 84,18 96,18 108,18 120,18 132,18 148,18"
                                          Stroke="#64748B"
                                          StrokeThickness="1.5"
                                          StrokeDashArray="4 4"
                                          Opacity="0.85" />
                            </Canvas>
                            <ProgressBar x:Name="GpuBar" Grid.Row="3" Height="8" Minimum="0" Maximum="100" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,14,0" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="诊断建议" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock x:Name="OverallStatusText"
                                                   Text="检测中"
                                                   Foreground="{StaticResource GoodBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="14,0,0,0" />
                                        <TextBlock x:Name="FindingCountText"
                                                   Text="0 个建议"
                                                   Foreground="#A9B7CC"
                                                   Margin="10,2,0,0" />
                                    </StackPanel>
                                    <TextBlock x:Name="SessionStateText"
                                               Text="所有动作先预览，执行前保存快照"
                                               Foreground="#A9B7CC"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                                <TextBlock x:Name="RefreshText"
                                           Grid.Column="1"
                                           Text="自动刷新"
                                           Foreground="#A9B7CC"
                                           VerticalAlignment="Top" />
                            </Grid>
                            <ListBox x:Name="FindingsList"
                                     Grid.Row="1"
                                     Margin="0,14,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#EEF4FF" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource GlassPanelStyle}" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Boost 预览" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="优化记录" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ListBox x:Name="PlanList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#EEF4FF" />
                                <ListBox x:Name="HistoryList"
                                         Grid.Column="1"
                                         Margin="12,0,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#EEF4FF" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="4"
                        Style="{StaticResource GlassPanelStyle}"
                        Padding="18"
                        Margin="0,18,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="210" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="游戏库" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="ActiveProfileText"
                                       Text="当前配置：无"
                                       Foreground="#A9B7CC"
                                       Margin="0,6,0,0" />
                            <ListBox x:Name="GameLibraryList"
                                     Margin="0,10,0,0"
                                     Height="54"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#EEF4FF"
                                     DisplayMemberPath="DisplayName"
                                     SelectionChanged="GameLibraryList_SelectionChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Button Height="32" Content="保存当前进程" Click="SaveSelectedGame_Click" />
                            <ComboBox x:Name="BackgroundCandidateCombo"
                                      Height="30"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="DisplayName" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Width="106" Height="30" Content="允许暂停" Click="AllowBackgroundCandidate_Click" />
                                <Button Width="94" Height="30" Margin="8,0,0,0" Content="删除配置" Click="DeleteActiveGame_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
