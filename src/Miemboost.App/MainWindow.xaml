<Window x:Class="Miemboost.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Miemboost"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" CornerRadius="16" GlassFrameThickness="0" ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border Margin="18"
            CornerRadius="18"
            BorderBrush="#435064"
            BorderThickness="1"
            Background="#111923">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#18212D"
                    CornerRadius="18,0,0,18"
                    BorderBrush="#2F3B4C"
                    BorderThickness="0,0,1,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,26">
                        <Border Width="34" Height="34" CornerRadius="9" Background="#273554">
                            <TextBlock Text="M" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="22"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Miemboost" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Button Style="{StaticResource NavButtonStyle}" Background="#303B58" Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock Text="总览" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="游戏库" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="一键加速" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="网络检测" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="进程管理" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="优化记录" />
                        </Button>
                    </StackPanel>

                    <Button Grid.Row="2" Style="{StaticResource NavButtonStyle}">
                        <TextBlock Text="设置" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Miemboost" Foreground="{StaticResource TextPrimaryBrush}" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Text="安静、可信、可恢复的游戏性能助手"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,8,0,0" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Width="36" Height="32" Content="-" Click="Minimize_Click" />
                        <Button Width="36" Height="32" Content="□" Click="Maximize_Click" Margin="8,0,0,0" />
                        <Button Width="36" Height="32" Content="×" Click="Close_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,26,0,18"
                        Padding="18"
                        CornerRadius="14"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        Background="{StaticResource PanelBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="当前模式" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="#263248" CornerRadius="10" Padding="14,8">
                                    <TextBlock Text="保守" Foreground="{StaticResource TextSecondaryBrush}" />
                                </Border>
                                <Border Background="#5669E8" CornerRadius="10" Padding="14,8" Margin="8,0,0,0">
                                    <TextBlock Text="平衡" Foreground="White" FontWeight="SemiBold" />
                                </Border>
                                <Border Background="#263248" CornerRadius="10" Padding="14,8" Margin="8,0,0,0">
                                    <TextBlock Text="激进" Foreground="{StaticResource TextSecondaryBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="已识别游戏" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <ComboBox x:Name="GameProcessCombo"
                                      Width="250"
                                      Height="34"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="GameProcessCombo_SelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Width="132"
                                    Height="58"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    BorderBrush="{StaticResource AccentBrushStrong}"
                                    Click="Boost_Click">
                                <TextBlock Text="Boost" />
                            </Button>
                            <Button x:Name="RestoreButton"
                                    Width="96"
                                    Height="58"
                                    Margin="10,0,0,0"
                                    Content="恢复"
                                    IsEnabled="False"
                                    Click="Restore_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="134" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="CPU" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock x:Name="CpuText" Text="--%" Foreground="{StaticResource TextPrimaryBrush}" FontSize="32"
                                       FontWeight="SemiBold" Margin="0,22,0,0" />
                            <TextBlock x:Name="CpuDetailText" Text="正在检测" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                            <ProgressBar x:Name="CpuBar" Height="8" Margin="0,28,0,0" Minimum="0" Maximum="100" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="内存" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock x:Name="MemoryText" Text="--%" Foreground="{StaticResource TextPrimaryBrush}" FontSize="32"
                                       FontWeight="SemiBold" Margin="0,22,0,0" />
                            <TextBlock x:Name="MemoryDetailText" Text="正在检测" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                            <ProgressBar x:Name="MemoryBar" Height="8" Margin="0,28,0,0" Minimum="0" Maximum="100" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="网络" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock x:Name="PingText" Text="-- ms" Foreground="{StaticResource GoodBrush}" FontSize="32"
                                       FontWeight="SemiBold" Margin="0,22,0,0" />
                            <TextBlock x:Name="NetworkDetailText" Text="Ping / 抖动 / 丢包" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                            <TextBlock x:Name="DnsText" Text="DNS -- ms" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,28,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="状态" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock x:Name="OverallStatusText" Text="检测中" Foreground="{StaticResource GoodBrush}" FontSize="32"
                                       FontWeight="SemiBold" Margin="0,22,0,0" />
                            <TextBlock x:Name="FindingCountText" Text="0 个建议" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                            <TextBlock Text="所有动作先预览，执行前保存快照" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,26,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Grid.ColumnSpan="4" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="0.9*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel>
                                    <TextBlock Text="诊断建议" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock x:Name="RefreshText" DockPanel.Dock="Right" Text="自动刷新"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </DockPanel>
                                <ListBox x:Name="FindingsList" Grid.Row="1" Margin="0,14,0,0"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextPrimaryBrush}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Boost 预览" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="优化记录" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ListBox x:Name="PlanList"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <ListBox x:Name="HistoryList" Grid.Column="1" Margin="12,0,0,0"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Grid.ColumnSpan="4" Margin="0,18,0,0"
                            Style="{StaticResource MetricCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="游戏库" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="ActiveProfileText"
                                           Text="Current profile: none"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,6,0,0" />
                                <ListBox x:Name="GameLibraryList" Margin="0,12,0,0" Height="58"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         DisplayMemberPath="DisplayName"
                                         SelectionChanged="GameLibraryList_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Width="190">
                                <Button Height="36" Content="保存当前进程"
                                        Click="SaveSelectedGame_Click" />
                                <ComboBox x:Name="BackgroundCandidateCombo"
                                          Height="32"
                                          Margin="0,8,0,0"
                                          DisplayMemberPath="DisplayName" />
                                <Button Height="34" Margin="0,8,0,0" Content="允许暂停候选"
                                        Click="AllowBackgroundCandidate_Click" />
                                <Button Height="30" Margin="0,8,0,0" Content="Delete profile"
                                        Click="DeleteActiveGame_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
